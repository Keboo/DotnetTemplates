@page "/Account/ResetPasswordConfirmation"
<PageTitle>Reset password confirmation</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Reset password confirmation</MudText>
<MudPaper Class="pa-4" Elevation="2">
    <MudAlert Severity="Severity.Success">
        Your password has been reset. Please <MudLink Href="Account/Login">click here to log in</MudLink>.
    </MudAlert>
</MudPaper>
