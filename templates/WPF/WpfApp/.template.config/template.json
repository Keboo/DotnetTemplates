{
  "$schema": "http://json.schemastore.org/template",
  "author": "Keboo",
  "classifications": [
    "Common",
    "WPF"
  ],
  "identity": "Keboo.WpfTemplates.FullApp",
  "name": "Keboo Full WPF Application",
  "description": "Creates a Windows-only WPF MVVM solution with optional tests and CI pipeline selection.",
  "shortName": "keboo.wpf",
  "icon": "favicon.ico",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "preferNameDirectory":true,
  "sourceName": "WpfApp",
  "constraints": {
    "windows-only": {
      "type": "os",
      "args": "Windows"
    }
  },
  "SpecialCustomOperations": {
    "**.slnx": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": [ "<!--#if" ],
            "else": [ "<!--#else" ],
            "elseif": [ "<!--#elseif" ],
            "endif": [ "<!--#endif" ],
            "trim": true,
            "wholeLine": true
          }
        }
      ]
    }
  },
  "symbols":{
    "user_secrets_id":{
      "type": "generated",
      "generator": "guid",
      "replaces": "12345678-9abc-0123-4567-890abcdef123",
      "parameters": {
        "defaultFormat":"d"
      }
    },
    "no-sln": {
      "type": "parameter",
      "dataType":"bool",
      "defaultValue": "false",
      "description": "Do not include a solution file."
    },
    "tests": {
      "type": "parameter",
      "dataType": "choice",
      "choices": [
        {
          "choice": "xunit",
          "description": "Use xUnit v3 testing framework"
        },
        {
          "choice": "mstest",
          "description": "Use MSTest testing framework"
        },
        {
          "choice": "tunit",
          "description": "Use TUnit testing framework"
        },
        {
          "choice": "none",
          "description": "Do not include tests"
        }
      ],
      "defaultValue": "tunit",
      "description": "The testing framework to use"
    },
    "useXunit": {
      "type": "computed",
      "value": "(tests == \"xunit\")"
    },
    "useMstest": {
      "type": "computed",
      "value": "(tests == \"mstest\")"
    },
    "useTunit": {
      "type": "computed",
      "value": "(tests == \"tunit\")"
    },
    "noTests": {
      "type": "computed",
      "value": "(tests == \"none\")"
    },
    "sln": {
      "type": "parameter",
      "dataType":"bool",
      "defaultValue": "false",
      "description": "Use legacy .sln format instead of .slnx format"
    },
    "pipeline": {
      "type": "parameter",
      "dataType": "choice",
      "choices": [
        {
          "choice": "github",
          "description": "Use GitHub Actions for CI/CD"
        },
        {
          "choice": "azuredevops",
          "description": "Use Azure DevOps Pipelines for CI/CD"
        },
        {
          "choice": "none",
          "description": "Do not include CI/CD pipeline files"
        }
      ],
      "defaultValue": "github",
      "description": "The CI/CD provider to use"
    },
    "useGitHub": {
      "type": "computed",
      "value": "(pipeline == \"github\")"
    },
    "useAzureDevOps": {
      "type": "computed",
      "value": "(pipeline == \"azuredevops\")"
    },
    "noPipeline": {
      "type": "computed",
      "value": "(pipeline == \"none\")"
    }
  },
  "primaryOutputs": [
    {
      "path": "WpfApp/WpfApp.csproj"
    },
    {
      "condition": "(noTests == \"False\")",
      "path": "WpfApp.Tests/WpfApp.Tests.csproj"
    }
  ],
  "sources": [
    {
      "modifiers": [
        {
          "condition": "(no-sln)",
          "exclude": [
            "WpfApp.sln",
            "WpfApp.slnx"
          ]
        },
        {
          "condition": "(sln == \"True\" && no-sln == \"False\")",
          "exclude": [
            "WpfApp.slnx"
          ]
        },
        {
          "condition": "(sln == \"False\" && no-sln == \"False\")",
          "exclude": [
            "WpfApp.sln"
          ]
        },
        {
          "condition": "(noTests)",
          "exclude": [
            "WpfApp.Tests/**",
            ".github/workflows/pr-code-coverage-comment.yml"
          ]
        },
        {
          "condition": "(useXunit)",
          "exclude": [
            "WpfApp.Tests/MainWindowViewModelTests.cs",
            "WpfApp.Tests/MainWindowViewModelTests.mstest.cs",
            "WpfApp.Tests/MainWindowViewModelTests.tunit.cs"
          ],
          "rename": {
            "MainWindowViewModelTests.xunit.cs": "MainWindowViewModelTests.cs"
          }
        },
        {
          "condition": "(useMstest)",
          "exclude": [
            "WpfApp.Tests/MainWindowViewModelTests.cs",
            "WpfApp.Tests/MainWindowViewModelTests.xunit.cs",
            "WpfApp.Tests/MainWindowViewModelTests.tunit.cs"
          ],
          "rename": {
            "MainWindowViewModelTests.mstest.cs": "MainWindowViewModelTests.cs"
          }
        },
        {
          "condition": "(useTunit)",
          "exclude": [
            "WpfApp.Tests/MainWindowViewModelTests.cs",
            "WpfApp.Tests/MainWindowViewModelTests.xunit.cs",
            "WpfApp.Tests/MainWindowViewModelTests.mstest.cs"
          ],
          "rename": {
            "MainWindowViewModelTests.tunit.cs": "MainWindowViewModelTests.cs"
          }
        },
        {
          "condition": "(useGitHub)",
          "exclude": [
            ".devops/**"
          ]
        },
        {
          "condition": "(useAzureDevOps)",
          "exclude": [
            ".github/**"
          ]
        },
        {
          "condition": "(noPipeline)",
          "exclude": [
            ".github/**",
            ".devops/**"
          ]
        }
      ]
    }
  ],
  "postActions": [
    {
      "condition": "(sln == \"True\" && no-sln == \"False\")",
      "description": "Restore NuGet packages required by this solution.",
      "manualInstructions": [
        {
          "text": "Run 'dotnet restore'"
        }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true,
      "args": {
        "files": [
          "WpfApp.sln"
        ]
      }
    },
    {
      "condition": "(sln == \"False\" && no-sln == \"False\")",
      "description": "Restore NuGet packages required by this solution.",
      "manualInstructions": [
        {
          "text": "Run 'dotnet restore'"
        }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true,
      "args": {
        "files": [
          "WpfApp.slnx"
        ]
      }
    },
    {
      "condition": "(no-sln == \"True\" && noTests == \"False\")",
      "description": "Restore NuGet packages required by these projects.",
      "manualInstructions": [
        {
          "text": "Run 'dotnet restore'"
        }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true,
      "args": {
        "files": [
          "WpfApp/WpfApp.csproj",
          "WpfApp.Tests/WpfApp.Tests.csproj"
        ]
      }
    },
    {
      "condition": "(no-sln == \"True\" && noTests == \"True\")",
      "description": "Restore NuGet packages required by this project.",
      "manualInstructions": [
        {
          "text": "Run 'dotnet restore'"
        }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true,
      "args": {
        "files": [
          "WpfApp/WpfApp.csproj"
        ]
      }
    }
  ]
}
